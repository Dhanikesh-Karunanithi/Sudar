# ByteOS Learn — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ============================================
# SUPABASE (Required — SAME project as byteos-studio)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# AUTH
# ============================================
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=same_secret_as_studio

# ============================================
# BYTEOS INTELLIGENCE SERVICE
# ============================================
BYTEOS_INTELLIGENCE_URL=http://localhost:8000

# ============================================
# ALP (Adaptive Learning Layer) — external LMS event ingestion
# ============================================
# Optional. If set, POST /api/alp/events requires x-alp-api-key or Authorization: Bearer <value>
# Used by SudarMemory (Moodle/Canvas connectors) to send learning events into Sudar.
# Learn also accepts keys from Studio → Integrations (integration_api_keys table).
ALP_API_KEY=

# Optional. Signing secret for embed tokens (iframe /alp/embed). Defaults to ALP_API_KEY if not set.
ALP_EMBED_SECRET=

# Optional. Used to build embed URLs (e.g. https://learn.yourorg.com). Fallback: request origin.
NEXT_PUBLIC_APP_URL=http://localhost:3001
