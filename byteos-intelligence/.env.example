# ByteOS Intelligence — Environment Variables

# AI Providers
TOGETHER_API_KEY=your_together_ai_key
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# Supabase (same project as Studio + Learn)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Microservices
BYTEOS_VIDEO_SERVICE_URL=http://localhost:5001
REMOTION_SERVER_URL=http://localhost:3040

# Server
PORT=8000
ENVIRONMENT=development

# ============================================
# SUDARPLAY (Modality 7 — game-based learning)
# ============================================
# JWT secret for signing launch tokens (WA → Sudar API auth). Use a long random string.
SUDARPLAY_JWT_SECRET=your_sudarplay_jwt_secret_min_32_chars
# Self-hosted WorkAdventure base URL (e.g. https://play.sudar.app)
WA_INSTANCE_URL=https://play.sudar.app
# Supabase Storage bucket name for generated maps (create bucket: sudarplay-maps, public read)
SUDARPLAY_MAPS_BUCKET=sudarplay-maps
# Default quiz gate pass threshold (0.0–1.0)
SUDARPLAY_DEFAULT_QUIZ_PASS_THRESHOLD=0.70
# Optional: WorkAdventure admin API key (if using WA admin API)
# WA_ADMIN_API_KEY=
# Optional: Piston API for code lab execution (default: https://emkc.org/api/v2/piston)
# PISTON_API_URL=https://emkc.org/api/v2/piston
